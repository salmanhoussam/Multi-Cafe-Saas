generator client {
  provider                    = "prisma-client-py"
  enable_experimental_decimal = true
  recursive_type_depth        = -1
  previewFeatures             = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public", "auth"]
}

model menu_items {
  id             String   @id @default(uuid()) @map("id")
  category_id    String   @map("category_id")
  restaurant_id  String   @map("restaurant_id")
  name_ar        String   @map("name_ar")
  name_en        String   @map("name_en")
  image_url      String?  @map("image_url")
  description_en String?  @map("description_en")
  description_ar String?  @map("description_ar")
  price          Decimal  @map("price")
  currency       String   @default("USD") @map("currency")
  is_available   Boolean  @default(true) @map("is_available")
  created_at     DateTime @default(now()) @map("created_at")

  categories categories? @relation(fields: [category_id], references: [id])
  restaurants restaurants? @relation(fields: [restaurant_id], references: [id])
  order_items order_items[]

  @@map("menu_items")
  @@schema("public")  // 👈 أضف هذا السطر
}

model categories {
  id            String   @id @default(uuid()) @map("id")
  restaurant_id String   @map("restaurant_id")
  name_ar       String   @map("name_ar")
  name_en       String   @map("name_en")
  sort_order    Int      @default(0) @map("sort_order")
  created_at    DateTime @default(now()) @map("created_at")
  image_url     String?  @map("image_url")

  restaurants  restaurants? @relation(fields: [restaurant_id], references: [id])
  menu_items   menu_items[]

  @@map("categories")
  @@schema("public")  // 👈 أضف هذا السطر
}

model orders {
  id             String   @id @default(uuid()) @map("id")
  restaurant_id  String   @map("restaurant_id")
  customer_name  String?  @map("customer_name")
  customer_phone String?  @map("customer_phone")
  items          Json     @map("items")
  total_price    Decimal  @map("total_price")
  currency       String   @default("USD") @map("currency")
  status         String   @default("PENDING") @map("status")
  created_at     DateTime @default(now()) @map("created_at")

  restaurants    restaurants? @relation(fields: [restaurant_id], references: [id])
  order_items    order_items[]

  @@map("orders")
  @@schema("public")  // 👈 أضف هذا السطر
}

model order_items {
  id           String   @id @default(uuid()) @map("id")
  order_id     String   @map("order_id")
  menu_item_id String   @map("menu_item_id")
  quantity     Int      @map("quantity")
  unit_price   Decimal  @map("unit_price")
  notes        String?  @map("notes")

  orders       orders?   @relation(fields: [order_id], references: [id])
  menu_items   menu_items? @relation(fields: [menu_item_id], references: [id])

  @@map("order_items")
  @@schema("public")  // 👈 أضف هذا السطر
}

model sales {
  id            String   @id @default(uuid()) @map("id")
  restaurant_id String   @map("restaurant_id")
  total_amount  Decimal  @map("total_amount")
  order_details Json?    @map("order_details")
  created_at    DateTime @default(now()) @map("created_at")

  restaurants   restaurants? @relation(fields: [restaurant_id], references: [id])

  @@map("sales")
  @@schema("public")  // 👈 أضف هذا السطر
}

model restaurants {
  id           String   @id @default(uuid()) @map("id")
  name_ar      String   @map("name_ar")
  name_en      String   @map("name_en")
  slug         String   @unique @map("slug")
  manager_phone String? @map("manager_phone")
  is_active    Boolean  @default(true) @map("is_active")
  image_url    String?  @map("image_url")
  created_at   DateTime @default(now()) @map("created_at")
  phone        String?  @map("phone")
  password     String   @map("password")
  manager_id   String?  @unique @map("manager_id")

  categories  categories[]
  menu_items  menu_items[]
  orders      orders[]
  sales       sales[]

  @@map("restaurants")
  @@schema("public")  // 👈 أضف هذا السطر
}